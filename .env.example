# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values. Never commit .env.local.
# Only TURSO_* + AUTH_SECRET + NEXT_PUBLIC_APP_URL are needed for Phase 1.
# ──────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
# Used for absolute URLs in emails, Stripe redirects, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Turso / libSQL) ────────────────────────────────────────────────
# Local dev:   TURSO_DATABASE_URL=file:./local.db   (leave auth token blank)
# Production:  get the URL + token from `turso db show <name>` and
#              `turso db tokens create <name>`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Admin auth (Phase 5) ─────────────────────────────────────────────────────
# AUTH_SECRET signs session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
# Email of the first admin (used by `pnpm seed:admin`).
ADMIN_SEED_EMAIL=

# ─── Stripe (Phase 4) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Get this from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# during dev, or from the dashboard webhook for production.
STRIPE_WEBHOOK_SECRET=

# ─── Cloudflare R2 (Phase 3) ──────────────────────────────────────────────────
# Create a private bucket, then an API token scoped to read+write on it.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Endpoint defaults to https://<account>.r2.cloudflarestorage.com — override
# only if you're using a custom domain in front of the bucket.
R2_ENDPOINT=

# ─── Email (Resend, Phase 5/6) ────────────────────────────────────────────────
RESEND_API_KEY=
# Must match a verified Resend domain. Example: "NextGen Diesel <orders@example.com>"
RESEND_FROM_EMAIL=
